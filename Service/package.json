{
  "name": "service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/app.js",
    "compile": "tsc *.ts --outDir js",
    "compile:watch": "npm run compile -- --watch *.ts",
    "test": "jest --coverage --silent=false --runInBand",
    "server": "NODE_ENV=development nodemon",
    "resetdata": "rimraf ./containers/data",
    "docker:start": "docker compose -f docker-compose.yml up",
    "docker:close": "docker compose down",
    "docker:init": "npm run resetdata && npm run docker:start",
    "lint": "eslint 'src/**/*.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.5",
    "axios": "^1.4.0",
    "body-parser": "^1.20.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^5.1.0",
    "supertest": "^6.3.3",
    "winston": "^3.18.3"
  }
}
